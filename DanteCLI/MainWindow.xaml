<Window x:Class="DanteCLI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DanteCLI.Views"
        Title="DANTE CLI" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">
    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Control" Command="{x:Static ApplicationCommands.New}" />
        <KeyBinding Key="W" Modifiers="Control" Command="{x:Static ApplicationCommands.Close}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{x:Static ApplicationCommands.Open}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="NewTab_Cmd" />
        <CommandBinding Command="{x:Static ApplicationCommands.Close}" Executed="CloseTab_Cmd" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="OpenFile_Cmd" />
    </Window.CommandBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="10,10,10,4">
                    <UniformGrid Columns="3" Margin="0">
                        <RadioButton x:Name="PickerFavorites"
                                     IsChecked="True" Click="Picker_Click" Tag="favorites"
                                     Style="{DynamicResource SegBtnStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⭐" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="Favoritos" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="PickerFiles"
                                     Click="Picker_Click" Tag="files"
                                     Style="{DynamicResource SegBtnStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📁" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="Pastas" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="PickerSnippets"
                                     Click="Picker_Click" Tag="snippets"
                                     Style="{DynamicResource SegBtnStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="▶" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="Snippets" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>
                </Border>

                <Grid Grid.Row="1">
                    <views:FavoritesSidebar x:Name="FavoritesPane" />
                    <views:FilesSidebar x:Name="FilesPane" Visibility="Collapsed" />
                    <TextBlock x:Name="SnippetsPlaceholder" Visibility="Collapsed"
                               Text="Snippets vão chegar na próxima versão Windows."
                               TextWrapping="Wrap" Foreground="#888" Padding="14"
                               HorizontalAlignment="Center" VerticalAlignment="Top" />
                </Grid>
            </Grid>
        </Border>

        <!-- Detail -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Update banner (visible only when an update is available) -->
            <views:UpdateBanner x:Name="UpdateBannerView" Grid.Row="0"
                                Visibility="Collapsed" />

            <!-- AI toolbar -->
            <Border Grid.Row="1" BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1" Padding="6,6">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Content="⚙" FontSize="14"
                            Background="Transparent" BorderThickness="0" Padding="8,4"
                            ToolTip="Configurações" Cursor="Hand"
                            Click="SettingsButton_Click" />
                    <Button DockPanel.Dock="Left" Content="ℹ" FontSize="14"
                            Background="Transparent" BorderThickness="0" Padding="8,4"
                            ToolTip="Sobre o DANTE CLI" Cursor="Hand"
                            Click="AboutButton_Click" />
                    <views:MicButton DockPanel.Dock="Left" />
                    <views:AILauncherToolbar x:Name="AIToolbar" DockPanel.Dock="Right" />
                </DockPanel>
            </Border>

            <!-- Tab strip -->
            <Border Grid.Row="2" BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1" Padding="6,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="TabStrip">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Column="1" x:Name="NewTabButton" ToolTip="Nova aba (Ctrl+T)"
                            Click="NewTabButton_Click" Background="Transparent"
                            BorderThickness="0" Padding="8,4" FontSize="14"
                            Content="+" Width="32" />
                </Grid>
            </Border>

            <!-- Tab body host: Canvas keeps tab views identity-stable across split mode changes -->
            <Canvas x:Name="TabsCanvas" Grid.Row="3" Background="#1A1B26"
                    SizeChanged="TabsCanvas_SizeChanged" ClipToBounds="True" />
        </Grid>
    </Grid>
</Window>
