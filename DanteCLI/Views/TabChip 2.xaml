<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DanteCLI.Views.TabChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="Root"
          PointerEntered="Root_PointerEntered"
          PointerExited="Root_PointerExited"
          Tapped="Root_Tapped"
          DoubleTapped="Root_DoubleTapped"
          Padding="10,5"
          CornerRadius="6"
          Background="{x:Bind BackgroundBrush, Mode=OneWay}">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock x:Name="EmojiBlock" FontSize="13" Visibility="Collapsed" />
            <Ellipse x:Name="ColorDot" Width="9" Height="9" />
            <TextBlock x:Name="TitleBlock" FontSize="12" />
            <Button x:Name="CloseButton" Click="CloseButton_Click"
                    Background="Transparent" BorderThickness="0" Padding="2"
                    Visibility="Collapsed">
                <FontIcon Glyph="&#xE10A;" FontSize="9" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
