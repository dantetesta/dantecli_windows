<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DanteCLI.Views.FavoritesSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="12,10" Spacing="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="FAVORITOS" FontSize="11" FontWeight="SemiBold" Opacity="0.6" />
                <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                        Click="AddButton_Click" ToolTipService.ToolTip="Adicionar favorito">
                    <FontIcon Glyph="&#xE710;" FontSize="13" />
                </Button>
            </Grid>
            <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Buscar... (Ctrl+L)"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged" />
        </StackPanel>

        <ListView x:Name="List"
                  Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="List_ItemClick"
                  Padding="6,0,6,8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6">
                        <StackPanel Orientation="Vertical" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Emoji}" FontSize="14" />
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium" />
                            </StackPanel>
                            <TextBlock Text="{Binding DisplayPath}" FontSize="10" Opacity="0.6" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
