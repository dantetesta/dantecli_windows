<UserControl x:Class="DanteCLI.Views.UpdateBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#0A84FF" Padding="12,6">
        <DockPanel>
            <TextBlock DockPanel.Dock="Left" Text="⬇" FontSize="14"
                       Foreground="White" VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <Button x:Name="CloseBtn" DockPanel.Dock="Right" Click="CloseBtn_Click"
                    Background="Transparent" BorderThickness="0" Padding="6,2"
                    Foreground="#DDFFFFFF" Cursor="Hand"
                    ToolTip="Dispensar (volte em Settings → Atualizações)">
                <TextBlock Text="✕" FontSize="11" FontWeight="Bold" />
            </Button>
            <Button x:Name="InstallBtn" DockPanel.Dock="Right" Click="InstallBtn_Click"
                    Background="White" Foreground="#0A84FF" BorderThickness="0"
                    Padding="10,4" Margin="0,0,8,0" Cursor="Hand">
                <TextBlock x:Name="InstallBtnText" Text="Baixar e instalar"
                           FontSize="11" FontWeight="SemiBold" />
            </Button>
            <ProgressBar x:Name="Progress" DockPanel.Dock="Right"
                         Width="120" Height="6" Margin="0,0,8,0"
                         Visibility="Collapsed" />
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="TitleText" Text="Atualização disponível"
                           FontSize="12" FontWeight="SemiBold" Foreground="White" />
                <TextBlock x:Name="NotesText" Text="" FontSize="10"
                           Foreground="#E6FFFFFF" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
