<UserControl x:Class="DanteCLI.Views.MicButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Name="Btn" Click="Btn_Click"
            Background="Transparent" BorderThickness="0"
            Padding="8,4" Cursor="Hand">
        <StackPanel Orientation="Horizontal">
            <Grid Width="18" Height="18" Margin="0,0,4,0">
                <TextBlock x:Name="Icon" Text="🎤" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Ellipse x:Name="RecDot" Width="14" Height="14" Fill="#FF453A"
                         Visibility="Collapsed" />
                <TextBlock x:Name="StopGlyph" Text="■" FontSize="10"
                           Foreground="White" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed" />
                <ProgressBar x:Name="Spinner" IsIndeterminate="True" Width="16" Height="16"
                             Visibility="Collapsed" />
            </Grid>
            <TextBlock x:Name="Label" Text="Voz" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>
