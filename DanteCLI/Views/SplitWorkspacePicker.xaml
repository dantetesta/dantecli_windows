<Window x:Class="DanteCLI.Views.SplitWorkspacePicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visão Dividida" Height="560" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Visão Dividida"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="TIPO" FontSize="11" FontWeight="SemiBold"
                   Foreground="#888" Margin="0,0,0,4" />
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,12" Height="32">
            <RadioButton x:Name="CatHorizontal" Content="Lado a lado"
                         IsChecked="True" Click="Category_Click" Tag="Horizontal"
                         Style="{DynamicResource SegBtnStyle}" />
            <RadioButton x:Name="CatVertical" Content="Empilhados"
                         Click="Category_Click" Tag="Vertical"
                         Style="{DynamicResource SegBtnStyle}" />
            <RadioButton x:Name="CatGrid" Content="Grade"
                         Click="Category_Click" Tag="Grid"
                         Style="{DynamicResource SegBtnStyle}" />
        </UniformGrid>

        <TextBlock Grid.Row="3" x:Name="LayoutHeader" Text="LAYOUT"
                   FontSize="11" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,6" />

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl x:Name="LayoutsList" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock x:Name="TabsHeader" Text="ABAS PRA INCLUIR"
                           FontSize="11" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,6" />
                <ItemsControl x:Name="TabsList" />
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="5" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock x:Name="CountLabel" DockPanel.Dock="Left"
                       Foreground="#666" FontSize="11" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="Aplicar" Padding="14,6"
                    Margin="6,0,0,0" Click="Apply_Click" IsDefault="True"
                    x:Name="ApplyButton" />
            <Button DockPanel.Dock="Right" Content="Cancelar" Padding="14,6"
                    IsCancel="True" Click="Cancel_Click" />
        </DockPanel>
    </Grid>

    <Window.Resources>
        <Style x:Key="SegBtnStyle" TargetType="RadioButton">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A0A84FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#11000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
