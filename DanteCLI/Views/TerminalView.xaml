<UserControl x:Class="DanteCLI.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1B26" Focusable="True"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown">
    <Grid Margin="10">
        <!-- OutputView is editable so PreviewTextInput fires, but every keystroke
             is intercepted (Handled = true). Content comes only from the PTY via
             code-behind setting Text directly. -->
        <TextBox x:Name="OutputView"
                 Background="Transparent" BorderThickness="0"
                 Foreground="#C0CAF5" CaretBrush="#7AA2F7"
                 SelectionBrush="#3E456A"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Mono, Consolas, Courier New"
                 FontSize="13" Padding="0"
                 UndoLimit="0"
                 PreviewKeyDown="Output_PreviewKeyDown"
                 PreviewTextInput="Output_PreviewTextInput"
                 GotKeyboardFocus="Output_GotKeyboardFocus" />
    </Grid>
</UserControl>
