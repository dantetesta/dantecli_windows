<UserControl x:Class="DanteCLI.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252537"
                BorderBrush="#3A3A4D" BorderThickness="0,0,0,1" Padding="10,6">
            <DockPanel>
                <TextBlock x:Name="LangChip" DockPanel.Dock="Right"
                           Background="#22FFFFFF" Padding="6,2" FontSize="10"
                           FontWeight="Medium" Margin="6,0,0,0" />
                <Button x:Name="SaveButton" DockPanel.Dock="Right"
                        Click="SaveButton_Click" IsEnabled="False"
                        Background="#0A84FF" Foreground="White"
                        BorderThickness="0" Padding="10,3" Margin="6,0,0,0"
                        Content="💾 Salvar" />
                <TextBlock x:Name="DirtyBadge" DockPanel.Dock="Right"
                           Foreground="#FFD60A" FontSize="11"
                           Text="● modificado" Margin="6,0,0,0"
                           Visibility="Collapsed" VerticalAlignment="Center" />
                <TextBlock x:Name="PathLabel" Foreground="#C0C0D0" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <avalon:TextEditor x:Name="Editor" Grid.Row="1"
                           FontFamily="Cascadia Mono, Consolas, Courier New"
                           FontSize="13"
                           Background="#1E1E2E"
                           Foreground="#D4D4D4"
                           LineNumbersForeground="#5A5A75"
                           ShowLineNumbers="True" />
    </Grid>
</UserControl>
