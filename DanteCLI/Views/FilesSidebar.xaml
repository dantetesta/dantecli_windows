<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DanteCLI.Views.FilesSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="12,10" Spacing="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="RootLabel" FontSize="12" FontWeight="SemiBold" />
                <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                        Click="ChooseRoot_Click" ToolTipService.ToolTip="Mudar pasta">
                    <FontIcon Glyph="&#xE712;" FontSize="13" />
                </Button>
                <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                        Click="Refresh_Click" ToolTipService.ToolTip="Recarregar">
                    <FontIcon Glyph="&#xE72C;" FontSize="13" />
                </Button>
            </Grid>
            <TextBlock x:Name="RootPath" FontSize="10" Opacity="0.6" TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <TreeView x:Name="Tree" Grid.Row="1" SelectionMode="Single" Padding="0,0,0,8" />
    </Grid>
</UserControl>
