<UserControl x:Class="DanteCLI.Views.FilesSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="12,8,12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="RootLabel" FontSize="12" FontWeight="SemiBold" />
                <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                        ToolTip="Mudar pasta" Click="ChooseRoot_Click" Content="📁" Width="28" />
                <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                        ToolTip="Recarregar" Click="Refresh_Click" Content="↻" Width="28" />
            </Grid>
            <TextBlock x:Name="RootPath" FontSize="10" Opacity="0.6"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <TreeView x:Name="Tree" Grid.Row="1" BorderThickness="0"
                  Background="Transparent" Padding="0,0,0,8" />
    </Grid>
</UserControl>
