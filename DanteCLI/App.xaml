<Application x:Class="DanteCLI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="SidebarBg"   Color="#F4F4F5" />
            <SolidColorBrush x:Key="DividerBrush" Color="#E0E0E0" />
            <SolidColorBrush x:Key="HoverBg"     Color="#22000000" />
            <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF" />
            <SolidColorBrush x:Key="MutedText"   Color="#666666" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
