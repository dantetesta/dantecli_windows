<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DanteCLI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:DanteCLI.Views"
    Title="DANTE CLI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <SelectorBar x:Name="SidebarPicker" Grid.Row="0" Margin="10,10,10,4">
                <SelectorBarItem Text="Favoritos" Tag="favorites" IsSelected="True" />
                <SelectorBarItem Text="Arquivos" Tag="files" />
            </SelectorBar>

            <Grid Grid.Row="1">
                <views:FavoritesSidebar x:Name="FavoritesPane" Visibility="Visible" />
                <views:FilesSidebar x:Name="FilesPane" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- Detail -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Tab strip -->
            <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1" Padding="6,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Disabled"
                                  Grid.Column="0">
                        <ItemsControl x:Name="TabStrip" />
                    </ScrollViewer>
                    <Button Grid.Column="1" x:Name="NewTabButton" ToolTipService.ToolTip="Nova aba (Ctrl+T)"
                            Click="NewTabButton_Click" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- Active tab body -->
            <Grid x:Name="TabsHost" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
